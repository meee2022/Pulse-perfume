# ==== PULSE Web — Environment ====
# انسخ الملف ده لاسم .env.local وحط مفاتيحك

# Stripe (اختياري). من غير المفاتيح دي الموقع بيشتغل في "وضع تجريبي" (Demo)
# ويسجّل الطلب محليًا بدل ما يوجّه لبوابة الدفع.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_ENABLED=false

# عنوان الموقع (للـ SEO و redirect بتاع الدفع)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Convex — باك-إند الطلبات والمنتجات
NEXT_PUBLIC_CONVEX_URL=https://notable-lemming-557.convex.cloud
# فعّلها true بعد نشر دوال Convex (npx convex dev). لو false الموقع يستخدم البيانات الثابتة.
NEXT_PUBLIC_CONVEX_ENABLED=false
# ملاحظة: ADMIN_KEY مفيش هنا — بتتحط في Convex نفسه:  npx convex env set ADMIN_KEY "your-password"
# ونفس الباسورد ده بتدخل بيه لوحة /admin
